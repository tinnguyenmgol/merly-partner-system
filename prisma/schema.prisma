generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PartnerTypeCode {
  referral_ctv
  mini_corner
  wholesale_agent
  shop_referral
  agency
  affiliate_creator
}

enum PartnerStatus {
  pending
  approved
  rejected
  suspended
  inactive
}

enum CommissionStatus {
  temporary
  pending_delivery
  reconciliation_waiting
  payable
  paid
  rejected
  on_hold
}

enum PayoutStatus {
  draft
  pending
  approved
  paid
  rejected
  cancelled
}

enum OrderAttributionSource {
  discount_code
  referral_link
  affiliate_link
  shop_discount_code
  manual
  order_request
  imported
}

enum RiskFlagStatus {
  open
  reviewing
  resolved
  dismissed
}

enum AdminRole {
  owner
  admin
  staff
}

enum AdminUserStatus {
  active
  disabled
}

model AdminUser {
  id           String          @id @default(cuid())
  email        String          @unique
  name         String?
  passwordHash String
  role         AdminRole       @default(admin)
  status       AdminUserStatus @default(active)
  lastLoginAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  sessions AdminAuthSession[]

  @@index([status])
}

model AdminAuthSession {
  id          String    @id @default(cuid())
  adminUserId String
  tokenHash   String    @unique
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?
  userAgent   String?
  ipHash      String?

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([expiresAt])
}

enum PartnerOrderRequestStatus {
  pending
  matched
  approved
  rejected
  cancelled
}

model PartnerType {
  id              String                  @id @default(cuid())
  code            PartnerTypeCode         @unique
  name            String
  description     String?
  enabled         Boolean                 @default(false)
  partners        Partner[]
  commissionRules PartnerCommissionRule[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
}

model Partner {
  id            String        @id @default(cuid())
  partnerTypeId String
  status        PartnerStatus @default(pending)
  email         String?       @unique
  phone         String?       @unique
  displayName   String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  partnerType     PartnerType               @relation(fields: [partnerTypeId], references: [id])
  profile         PartnerProfile?
  codes           PartnerCode[]
  orders          PartnerOrder[]
  ledgerEntries   PartnerCommissionLedger[]
  payouts         PartnerPayout[]
  riskFlags       PartnerRiskFlag[]
  auditLogs       AdminAuditLog[]
  clicks          PartnerClick[]
  statementTokens PartnerStatementToken[]
  orderRequests   PartnerOrderRequest[]
  announcementReads PartnerAnnouncementRead[]
  shortLinks      ShortLink[]
  shortLinkClicks ShortLinkClick[]
  account         PartnerAccount?
}

model PartnerProfile {
  id                         String   @id @default(cuid())
  partnerId                  String   @unique
  fullName                   String
  contactName                String?
  shopName                   String?
  businessName               String?
  storeAddress               String?
  warehouseAddress           String?
  cityProvince               String?
  salesChannel               String?
  customerSegment            String?
  displayAreaNote            String?
  expectedDisplayQuantity    Int?
  businessModelNote          String?
  expectedOpeningOrderAmount Int?
  coverageArea               String?
  taxCode                    String?
  hasOfflineStore            Boolean?
  hasLivestream              Boolean?
  zalo                       String?
  area                       String?
  sellingChannel             String?
  socialLink                 String?
  experienceNote             String?
  bankAccountHolder          String?
  bankName                   String?
  bankAccountNumber          String?

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
}

model PartnerCode {
  id                  String                 @id @default(cuid())
  partnerId           String
  code                String                 @unique
  source              OrderAttributionSource @default(affiliate_link)
  codePurpose         String                 @default("affiliate_tracking")
  commissionRateBps   Int?
  customerDiscountBps Int?
  active              Boolean                @default(true)
  createdAt           DateTime               @default(now())

  partner      Partner                   @relation(fields: [partnerId], references: [id])
  attributions PartnerOrderAttribution[]
  clicks       PartnerClick[]

  @@index([codePurpose])
}

model PartnerClick {
  id            String   @id @default(cuid())
  partnerId     String
  partnerCodeId String
  partnerCode   String
  clickId       String
  landingUrl    String?
  currentUrl    String?
  referrer      String?
  source        String?
  userAgent     String?
  ipHash        String?
  occurredAt    DateTime
  createdAt     DateTime @default(now())

  partner Partner     @relation(fields: [partnerId], references: [id])
  code    PartnerCode @relation(fields: [partnerCodeId], references: [id])

  @@index([partnerCode])
  @@index([clickId])
  @@index([partnerId])
  @@index([occurredAt])
}

model PartnerLevel {
  id          String   @id @default(cuid())
  name        String   @unique
  rank        Int
  description String?
  createdAt   DateTime @default(now())

  rules PartnerLevelRule[]
}

model PartnerLevelRule {
  id                       String  @id @default(cuid())
  levelId                  String
  successfulOrdersRequired Int
  commissionRateBps        Int?
  requiresAdminApproval    Boolean @default(true)

  level PartnerLevel @relation(fields: [levelId], references: [id])
}

model PartnerOrder {
  id                     String    @id @default(cuid())
  partnerId              String?
  externalOrderId        String?   @unique
  orderCode              String    @unique
  customerName           String?
  status                 String    @default("created")
  eligibleProductRevenue Int       @map("eligible_product_revenue")
  discountAmount         Int       @default(0)
  shippingFee            Int       @default(0)
  surchargeAmount        Int       @default(0)
  nonProductFeeAmount    Int       @default(0)
  paidAt                 DateTime?
  deliveredAt            DateTime?
  cancelledAt            DateTime?
  returnedAt             DateTime?
  disputedAt             DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  partner       Partner?                  @relation(fields: [partnerId], references: [id])
  items         PartnerOrderItem[]
  attributions  PartnerOrderAttribution[]
  ledgerEntries PartnerCommissionLedger[]
  orderRequests PartnerOrderRequest[]
}

model PartnerOrderRequest {
  id             String                    @id @default(cuid())
  partnerId      String
  status         PartnerOrderRequestStatus @default(pending)
  orderCode      String?
  contactHint    String?
  expectedAmount Int?
  note           String?
  matchedOrderId String?
  adminNote      String?
  rejectReason   String?
  approvedAt     DateTime?
  rejectedAt     DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  partner      Partner       @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  matchedOrder PartnerOrder? @relation(fields: [matchedOrderId], references: [id], onDelete: SetNull)

  @@index([partnerId, status, createdAt])
  @@index([status, createdAt])
  @@index([orderCode])
  @@index([matchedOrderId])
}

model PartnerOrderItem {
  id              String  @id @default(cuid())
  orderId         String
  sku             String?
  productName     String
  quantity        Int
  unitPrice       Int
  discountAmount  Int     @default(0)
  eligibleRevenue Int

  order PartnerOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model PartnerOrderAttribution {
  id            String                 @id @default(cuid())
  orderId       String
  partnerCodeId String?
  source        OrderAttributionSource
  value         String?
  note          String?
  createdAt     DateTime               @default(now())

  order       PartnerOrder @relation(fields: [orderId], references: [id])
  partnerCode PartnerCode? @relation(fields: [partnerCodeId], references: [id])
}

model PartnerCommissionRule {
  id                   String   @id @default(cuid())
  partnerTypeId        String
  name                 String
  description          String?
  minDiscountBps       Int?
  maxDiscountBps       Int?
  commissionRateBps    Int?
  manualReviewRequired Boolean  @default(false)
  unauthorizedDiscount Boolean  @default(false)
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  partnerType PartnerType @relation(fields: [partnerTypeId], references: [id])
}

model PartnerCommissionLedger {
  id                     String           @id @default(cuid())
  partnerId              String
  orderId                String?
  status                 CommissionStatus @default(temporary)
  amount                 Int
  commissionRateBps      Int?
  eligibleProductRevenue Int              @map("eligible_product_revenue")
  reason                 String?
  availableAt            DateTime?
  paidAt                 DateTime?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  partner     Partner             @relation(fields: [partnerId], references: [id])
  order       PartnerOrder?       @relation(fields: [orderId], references: [id])
  payoutItems PartnerPayoutItem[]

  @@unique([orderId])
}

model PartnerAccount {
  id            String    @id @default(cuid())
  partnerId     String    @unique
  email         String?   @unique
  phone         String?   @unique
  passwordHash  String?
  status        String    @default("invited")
  lastLoginAt   DateTime?
  passwordSetAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  partner  Partner              @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  sessions PartnerAuthSession[]
  tokens   PartnerAuthToken[]

  @@index([status])
}

model PartnerAuthSession {
  id        String    @id @default(cuid())
  accountId String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ipHash    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  account PartnerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([expiresAt])
}

model PartnerAuthToken {
  id        String    @id @default(cuid())
  accountId String
  tokenHash String    @unique
  purpose   String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  account PartnerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([purpose])
  @@index([expiresAt])
}

model PartnerStatementToken {
  id        String    @id @default(cuid())
  partnerId String
  tokenHash String    @unique
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
}

model PartnerPayout {
  id                  String       @id @default(cuid())
  partnerId           String
  status              PayoutStatus @default(draft)
  periodStart         DateTime
  periodEnd           DateTime
  amount              Int
  minimumPayoutAmount Int          @default(100000)
  rolloverAmount      Int          @default(0)
  requestedAt         DateTime?
  approvedAt          DateTime?
  paidAt              DateTime?
  rejectedAt          DateTime?
  rejectReason        String?
  lastReconciledAt    DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  partner Partner             @relation(fields: [partnerId], references: [id])
  items   PartnerPayoutItem[]
}

model PartnerPayoutItem {
  id       String @id @default(cuid())
  payoutId String
  ledgerId String
  amount   Int

  payout PartnerPayout           @relation(fields: [payoutId], references: [id])
  ledger PartnerCommissionLedger @relation(fields: [ledgerId], references: [id])

  @@unique([ledgerId])
}

model PartnerRiskFlag {
  id        String         @id @default(cuid())
  partnerId String
  orderId   String?
  status    RiskFlagStatus @default(open)
  reason    String
  detail    String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  partner Partner @relation(fields: [partnerId], references: [id])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  partnerId  String?
  action     String
  entityType String
  entityId   String
  beforeJson Json?
  afterJson  Json?
  note       String?
  createdAt  DateTime @default(now())

  partner Partner? @relation(fields: [partnerId], references: [id])
}

model PartnerProgramSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model PartnerAnnouncement {
  id                String    @id @default(cuid())
  title             String
  body              String
  category          String    @default("general")
  priority          String    @default("normal")
  publishAt         DateTime  @default(now())
  expiresAt         DateTime?
  ctaLabel          String?
  ctaUrl            String?
  pinned            Boolean   @default(false)
  archivedAt        DateTime?
  targetPartnerType PartnerTypeCode @default(referral_ctv)
  createdByAdminId  String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  reads PartnerAnnouncementRead[]

  @@index([targetPartnerType, publishAt, expiresAt, archivedAt])
  @@index([pinned, priority])
}

model PartnerAnnouncementRead {
  id             String   @id @default(cuid())
  announcementId String
  partnerId      String
  readAt         DateTime @default(now())

  announcement PartnerAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  partner      Partner             @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([announcementId, partnerId])
  @@index([partnerId, readAt])
}

model ShortLink {
  id          String    @id @default(cuid())
  partnerId   String
  slug        String    @unique
  destinationUrl String
  disabledAt  DateTime?
  disabledReason String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  clicks  ShortLinkClick[]

  @@index([partnerId, createdAt])
  @@index([disabledAt])
}

model ShortLinkClick {
  id          String   @id @default(cuid())
  shortLinkId String
  partnerId   String
  userAgent   String?
  ipHash      String?
  referrer    String?
  clickedAt   DateTime @default(now())

  shortLink ShortLink @relation(fields: [shortLinkId], references: [id], onDelete: Cascade)
  partner   Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([shortLinkId, clickedAt])
  @@index([partnerId, clickedAt])
}

model HaravanSyncLog {
  id         String    @id @default(cuid())
  syncType   String
  status     String
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  message    String?
  metadata   Json?
}
